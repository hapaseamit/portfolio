@echo off
setlocal

echo.
set /p USERNAME=Enter the local username you want to create: 

if "%USERNAME%"=="" (
    echo.
    echo Username cannot be empty.
    pause
    exit /b
)

echo.
echo Username: %USERNAME%
echo.

:: Download unattend.xml
curl -L "https://raw.githubusercontent.com/hapaseamit/windowslocal/refs/heads/main/unattend.xml" -o "C:\Windows\Panther\unattend.xml"

:: Replace required values in XML
powershell -Command ^
"$username='%USERNAME%'; ^
(Get-Content 'C:\Windows\Panther\unattend.xml') ^
-replace '<Name>Admin</Name>', ('<Name>' + $username + '</Name>') ^
-replace '<Username>Admin</Username>', ('<Username>' + $username + '</Username>') ^
| Set-Content 'C:\Windows\Panther\unattend.xml'"

:: Run Sysprep
%WINDIR%\System32\Sysprep\Sysprep.exe /oobe /unattend:C:\Windows\Panther\unattend.xml /reboot